# RSS reader
RSS_FEEDS_FILE=/app/configs/feeds.txt
RSS_FEEDS=
RSS_BOOTSTRAP_MARK_EXISTING=false
RSS_COLD_START_ITEMS_PER_FEED=3
RSS_POLL_INTERVAL=15m
RSS_RETRY_ATTEMPTS=5
RSS_RETRY_BASE_DELAY=2s
RSS_COOLDOWN_RETRY=6h
RSS_DB_PATH=/data/rss-reader.db
RSS_MAX_ITEMS_PER_POLL=100
WEB_ADMIN_PORT=8090

# test-rss mini site
TEST_RSS_PORT=8095
TEST_RSS_BASE_URL=http://test-rss:8095
TEST_RSS_PUBLISH_INTERVAL=5m
TEST_RSS_MAX_FEED_ITEMS=10
TEST_RSS_SITE_TITLE=RWCT Test Jobs

# Resource/run guards
RETENTION_HOURS=168
RETENTION_CLEANUP_EVERY=1h

# Analyzer (CPU-safe defaults)
LLM_ENDPOINT=http://llm-mock:8080
# Logical model name sent by the analyzer in API requests.
# If you use llama.cpp locally, keep this aligned with LLM_MODEL_FILE unless
# your endpoint expects a different alias.
LLM_MODEL=qwen3.5-0.8b-instruct-q4_k_m.gguf
LLM_TIMEOUT=20s
LLM_TIMEOUT_MAX=10m
LLM_TIMEOUT_PER_1K_CHARS=25s
LLM_TIMEOUT_PER_256_TOKENS=20s
LLM_MAX_TOKENS=512
LLM_THINKING_ENABLED=false
ANALYZER_LLM_STRICT_JSON=true
# Optional custom prompt templates (Go text/template syntax).
# Available variables: AllowedCategories, Title, URL, Description, SourcePageText, LinksCSV, ImagesCSV.
# Example:
# ANALYZER_PROMPT_TEMPLATE=Analizza annuncio e restituisci SOLO JSON con campi ...\nCategorie: {{.AllowedCategories}}\nTitolo: {{.Title}}\nURL: {{.URL}}\nDescrizione: {{.Description}}\nSorgente: {{.SourcePageText}}\nLink: {{.LinksCSV}}\nImmagini: {{.ImagesCSV}}
ANALYZER_PROMPT_TEMPLATE=
ANALYZER_COMPACT_PROMPT_TEMPLATE=
# Source extraction strategy for job source page enrichment:
# off | basic | scrapling | hybrid
ANALYZER_SOURCE_EXTRACTOR=basic
# In hybrid mode, fallback to scrapling when basic extraction is shorter than this threshold.
ANALYZER_SOURCE_MIN_CHARS_FOR_BASIC=220
ANALYZER_SCRAPLING_ENDPOINT=http://scrapling-sidecar:8088
ANALYZER_SCRAPLING_TIMEOUT=8s
ANALYZER_SCRAPLING_MAX_CHARS=10000
# Max jobs analyzed in parallel by one job-analyzer process.
# NOTE: current implementation enforces strict sequential mode, so effective value is 1.
ANALYZER_MAX_PARALLEL_JOBS=1
LLM_MAX_JOBS_PER_MIN=20
ANALYZER_QUEUE_POLL_INTERVAL=1200ms
ANALYZER_QUEUE_LEASE_DURATION=2m

# Dispatcher
DESTINATION_MODE=file
FILE_SINK_PATH=/data/outbox/messages.md
DISPATCH_TEMPLATE_FILE=/app/configs/message.tmpl.md
TELEGRAM_TEMPLATE_FILE=/app/configs/message.telegram.tmpl.md
DISPATCH_RATE_LIMIT_PER_MIN=10
DISPATCH_QUEUE_POLL_INTERVAL=1200ms
DISPATCH_QUEUE_LEASE_DURATION=2m
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
TELEGRAM_PARSE_MODE=Markdown
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=false
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Retry / DLQ
DLQ_RETRY_ATTEMPTS=3
DLQ_RETRY_BASE_DELAY=2s

# OpenTelemetry
# I servizi applicativi inviano sempre all'otel-collector locale.
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
SERVICE_VERSION=dev
DEPLOY_ENV=local

# Observability UI
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# llama.cpp (prod profile)
# Filesystem model used by the local llama.cpp container.
# This is the GGUF filename under LLM_MODELS_DIR and is independent from
# LLM_MODEL only when your inference endpoint maps names differently.
LLM_MODELS_DIR=./models
LLM_MODEL_FILE=qwen3.5-0.8b-instruct-q4_k_m.gguf
# llama.cpp parallel CPU threads (-t).
# Upstream default is -1 (auto-detect); keep -1 unless you need manual tuning.
LLM_PARALLEL_THREADS=-1
# Enable llama.cpp Prometheus metrics endpoint (/metrics).
LLAMA_ENABLE_METRICS=true
