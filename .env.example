# RSS reader
RSS_FEEDS_FILE=/app/configs/feeds.txt
RSS_FEEDS=
RSS_BOOTSTRAP_MARK_EXISTING=false
RSS_COLD_START_ITEMS_PER_FEED=3
RSS_POLL_INTERVAL=15m
RSS_RETRY_ATTEMPTS=5
RSS_RETRY_BASE_DELAY=2s
RSS_COOLDOWN_RETRY=6h
RSS_DB_PATH=/data/rss-reader.db
RSS_MAX_ITEMS_PER_POLL=100
WEB_ADMIN_PORT=8090

# Resource/run guards
RETENTION_HOURS=168
RETENTION_CLEANUP_EVERY=1h

# Analyzer (CPU-safe defaults)
LLM_ENDPOINT=http://llm-mock:8080
LLM_MODEL=qwen3.5-0.8b-instruct-q4_k_m.gguf
LLM_TIMEOUT=20s
LLM_MAX_TOKENS=512
LLM_THINKING_ENABLED=false
LLM_MAX_CONCURRENCY=1
LLM_MAX_JOBS_PER_MIN=20
ANALYZER_QUEUE_POLL_INTERVAL=1200ms
ANALYZER_QUEUE_LEASE_DURATION=2m

# Dispatcher
DESTINATION_MODE=file
FILE_SINK_PATH=/data/outbox/messages.md
DISPATCH_TEMPLATE_FILE=/app/configs/message.tmpl.md
TELEGRAM_TEMPLATE_FILE=/app/configs/message.telegram.tmpl.md
DISPATCH_RATE_LIMIT_PER_MIN=30
DISPATCH_QUEUE_POLL_INTERVAL=1200ms
DISPATCH_QUEUE_LEASE_DURATION=2m
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
TELEGRAM_PARSE_MODE=Markdown
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=false
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Retry / DLQ
DLQ_RETRY_ATTEMPTS=3
DLQ_RETRY_BASE_DELAY=2s

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=

# llama.cpp (prod profile)
LLM_MODELS_DIR=./models
LLM_MODEL_FILE=qwen3.5-0.8b-instruct-q4_k_m.gguf
